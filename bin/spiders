#!/usr/bin/env bash
# 🕸 spider.Web — launch from anywhere
# Default: Tauri desktop app (dashboard) + TUI (chat)
cd "$(dirname "$(readlink -f "$0")")/../spider.Web"
source .venv/bin/activate

# Start docker if not running
docker compose up -d 2>/dev/null

# Start server via systemd (survives terminal close)
if ! curl -s http://localhost:8420/health >/dev/null 2>&1; then
    echo "🕸 Starting spider.Web..."
    systemctl --user start spider-web 2>/dev/null || {
        uvicorn agentic_hub.main:app --host 127.0.0.1 --port 8420 &>/tmp/spider-web-server.log &
    }
    for i in $(seq 1 20); do
        sleep 0.5
        curl -s http://localhost:8420/health >/dev/null 2>&1 && break
    done
fi

# Auth token — copy to clipboard so TUI doesn't eat it
if [ -f /tmp/.spider-web-token ]; then
    TOKEN=$(cat /tmp/.spider-web-token)
    COPIED=0
    if [ "$XDG_SESSION_TYPE" = "x11" ]; then
        # X11 session — use X11 clipboard tools
        if command -v xclip &>/dev/null; then
            echo -n "$TOKEN" | xclip -selection clipboard && COPIED=1
        elif command -v xsel &>/dev/null; then
            echo -n "$TOKEN" | xsel --clipboard && COPIED=1
        fi
    else
        # Wayland session
        if command -v wl-copy &>/dev/null; then
            echo -n "$TOKEN" | wl-copy && COPIED=1
        fi
    fi
    if [ "$COPIED" = "1" ]; then
        echo "  🔑 Auth token copied to clipboard"
    else
        echo "  🔑 Token: $TOKEN"
    fi
fi

# Launch Tauri desktop dashboard (non-blocking)
if [ -x "$HOME/bin/spider-web-desktop" ]; then
    nohup "$HOME/bin/spider-web-desktop" &>/dev/null &
fi

# Launch TUI for chat
hub tui
