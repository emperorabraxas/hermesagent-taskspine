# Spider Web Configuration

# Cloud API Keys (each spider uses the best API for its role)
# Automator: Claude Opus (best tool use)
ANTHROPIC_API_KEY=sk-ant-...
# Oracle + Code Team coder: OpenAI (GPT-4o chat, GPT-4.1 coding)
OPENAI_API_KEY=sk-...
# Scholar: Gemini 2.5 Pro (best research/reasoning)
GOOGLE_API_KEY=AIza...
# Code Team reviewer + Orchestrator: DeepSeek R1 (best reasoning per dollar)
DEEPSEEK_API_KEY=sk-...

# Semantic Scholar (optional — free API, key increases rate limit to 100 req/s)
SEMANTIC_SCHOLAR_API_KEY=

# Plaid (bank account integration — sandbox free, production requires approval)
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENVIRONMENT=sandbox

# All keys are optional — each spider falls back to local uncensored Dolphin models

# Ollama
OLLAMA_BASE_URL=http://localhost:11434

# Database
DATABASE_URL=postgresql+asyncpg://hub:hub_local_dev@localhost:5434/agentic_hub

# Redis
REDIS_URL=redis://localhost:6380/0

# Server — SECURITY: 127.0.0.1 = localhost only. Use 0.0.0.0 to expose to LAN.
HUB_HOST=127.0.0.1
HUB_PORT=8420

# CORS — additional origins (comma-separated). Localhost always allowed.
CORS_ORIGINS=

# Database password (used by docker-compose)
POSTGRES_PASSWORD=
