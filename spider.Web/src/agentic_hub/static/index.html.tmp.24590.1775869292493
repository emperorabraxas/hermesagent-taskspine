.modal-btns{display:flex;gap:0.5rem;justify-content:flex-end}
.btn-g{background:none;border:1px solid var(--border2);color:var(--dim);padding:0.4rem 0.8rem;cursor:pointer;font-family:'JetBrains Mono';font-size:0.72rem}
.btn-p{background:var(--red);border:none;color:#fff;padding:0.4rem 1rem;cursor:pointer;font-family:'Space Grotesk';font-weight:700;font-size:0.72rem}

@media(max-width:768px){.hull{transform:translate(-50%,-50%) scale(0.5)}.st-grid{grid-template-columns:repeat(2,1fr)}.n-stats{display:none}.ship-panel{height:220px}}
</style>
