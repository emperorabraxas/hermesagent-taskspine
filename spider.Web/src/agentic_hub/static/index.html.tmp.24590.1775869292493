<script>
const A='';let sid=null;
const RANKS=[[0,'見習い — Apprentice'],[5,'糸紡ぎ — Thread Spinner'],[10,'織り手 — Weaver'],[25,'絹職人 — Silk Artisan'],[50,'蜘蛛王 — Arachnid Lord'],[100,'蜘蛛神 — Spider God']];
function rank(l){let r=RANKS[0][1];for(const[v,n]of RANKS)if(l>=v)r=n;return r}

// Nav
function go(t){
    document.querySelectorAll('.view,.page').forEach(e=>e.classList.remove('active'));
    document.querySelectorAll('.n-tab').forEach(e=>e.classList.remove('active'));
    const el=document.getElementById('v-'+t);if(el)el.classList.add('active');
    document.querySelector(`.n-tab[data-t="${t}"]`)?.classList.add('active');
    if(t==='models')loadModels();if(t==='settings')loadPrefs();
    if(t==='bridge')document.getElementById('chat-in')?.focus();
}

// Ship layout
const DL={cockpit:{x:10,y:110,w:100,h:100},scholar:{x:150,y:10,w:130,h:100},oracle:{x:150,y:210,w:130,h:100},ops:{x:310,y:100,w:110,h:110},automator:{x:460,y:10,w:120,h:100},code_team:{x:460,y:210,w:120,h:100},lab:{x:600,y:110,w:110,h:100}};
const CONNS=[['cockpit','scholar'],['cockpit','oracle'],['scholar','ops'],['oracle','ops'],['ops','automator'],['ops','code_team'],['ops','lab'],['lab','automator'],['lab','code_team']];
let SL={};let editing=false;

function loadSL(){const s=localStorage.getItem('sw-layout');if(s)try{SL=JSON.parse(s);return}catch(e){}SL=JSON.parse(JSON.stringify(DL))}
function saveSL(){localStorage.setItem('sw-layout',JSON.stringify(SL))}
function applySL(){for(const[id,p]of Object.entries(SL)){const e=document.getElementById('room-'+id);if(!e)continue;e.style.cssText=`position:absolute;left:${p.x}px;top:${p.y}px;width:${p.w}px;height:${p.h}px`}drawCorr()}
function drawCorr(){
    const svg=document.getElementById('corr-svg');if(!svg)return;
    let h='';
    // Find web center (ops center or average of all rooms)
    const ops=SL.ops;
    const cx=ops?ops.x+ops.w/2:360, cy=ops?ops.y+ops.h/2:160;

    // Draw concentric web rings
    for(let r=60;r<=200;r+=45){
        h+=`<circle class="web-ring" cx="${cx}" cy="${cy}" r="${r}"/>`;
    }

    // Draw radial lines from center to every room
    for(const[id,rm] of Object.entries(SL)){
        if(!rm)continue;
        const rx=rm.x+rm.w/2, ry=rm.y+rm.h/2;
        h+=`<line class="web-radial" x1="${cx}" y1="${cy}" x2="${rx}" y2="${ry}"/>`;
    }

    // Draw silk strands between connected rooms
    for(const[a,b]of CONNS){
        const ra=SL[a],rb=SL[b];if(!ra||!rb)continue;
        const ax=ra.x+ra.w/2,ay=ra.y+ra.h/2,bx=rb.x+rb.w/2,by=rb.y+rb.h/2;
        // Slight curve for organic web feel
        const mx=(ax+bx)/2+(Math.random()-0.5)*10, my=(ay+by)/2+(Math.random()-0.5)*10;
        h+=`<path class="corr-glow" d="M${ax},${ay} Q${mx},${my} ${bx},${by}"/>`;
        h+=`<path class="corr-main" d="M${ax},${ay} Q${mx},${my} ${bx},${by}"/>`;
    }

    svg.innerHTML=h;
}
function toggleEdit(){editing=!editing;const h=document.getElementById('hull');h.classList.toggle('edit-on',editing);document.getElementById('edit-btn').classList.toggle('on',editing);document.getElementById('edit-btn').textContent=editing?'✓ Done':'🔧 Edit';document.getElementById('reset-btn').style.display=editing?'inline':'none';document.querySelectorAll('.s-room').forEach(r=>r.classList.toggle('draggable',editing))}
function resetShip(){if(!confirm('Reset layout?'))return;SL=JSON.parse(JSON.stringify(DL));saveSL();applySL()}
function initDrag(){const h=document.getElementById('hull');if(!h)return;h.addEventListener('pointerdown',e=>{if(!editing)return;const rm=e.target.closest('.s-room');if(!rm)return;e.preventDefault();rm.setPointerCapture(e.pointerId);const k=rm.id.replace('room-','');if(!SL[k])return;const rc=h.getBoundingClientRect();const ox=e.clientX-rc.left-SL[k].x,oy=e.clientY-rc.top-SL[k].y;rm.classList.add('dragging');const mv=ev=>{let nx=Math.round((ev.clientX-rc.left-ox)/10)*10,ny=Math.round((ev.clientY-rc.top-oy)/10)*10;nx=Math.max(0,Math.min(720-SL[k].w,nx));ny=Math.max(0,Math.min(320-SL[k].h,ny));SL[k].x=nx;SL[k].y=ny;rm.style.left=nx+'px';rm.style.top=ny+'px';drawCorr()};const up=()=>{rm.classList.remove('dragging');rm.removeEventListener('pointermove',mv);rm.removeEventListener('pointerup',up);saveSL()};rm.addEventListener('pointermove',mv);rm.addEventListener('pointerup',up)})}

// Stars
function initStars(){const el=document.getElementById('stars');if(!el)return;let h='';for(let i=0;i<60;i++){const x=Math.random()*100,y=Math.random()*100,s=Math.random()+0.5,d=Math.random()*5;h+=`<div class="star" style="left:${x}%;top:${y}%;width:${s}px;height:${s}px;animation-delay:${d}s"></div>`}el.innerHTML=h}

// Agent walk system
const HOME_ROOM={scholar:'scholar',oracle:'oracle',automator:'automator'};
function rc(id){const r=SL[id];return r?{x:r.x+r.w/2,y:r.y+r.h/2}:{x:360,y:160}}
function bfs(from,to){if(from===to)return[to];const adj={};for(const[a,b]of CONNS){(adj[a]=adj[a]||[]).push(b);(adj[b]=adj[b]||[]).push(a)}const q=[[from,[from]]],vis=new Set([from]);while(q.length){const[n,p]=q.shift();for(const nb of(adj[n]||[])){if(vis.has(nb))continue;const np=[...p,nb];if(nb===to)return np;vis.add(nb);q.push([nb,np])}}return[from,to]}
function walkTo(el,wps,cb){if(!el||!wps.length)return;el.classList.remove('idle','working');el.classList.add('walking');const hull=document.getElementById('hull');if(el.parentElement!==hull){const hr=hull.getBoundingClientRect(),cr=el.getBoundingClientRect();el.style.position='absolute';el.style.left=(cr.left-hr.left)+'px';el.style.top=(cr.top-hr.top)+'px';hull.appendChild(el)}let wi=0;const SPD=1.8;(function step(){if(wi>=wps.length){el.classList.remove('walking');el.classList.add('working');if(cb)cb();return}const t=wps[wi],cx=parseFloat(el.style.left)||0,cy=parseFloat(el.style.top)||0,dx=t.x-cx,dy=t.y-cy,d=Math.sqrt(dx*dx+dy*dy);if(d<SPD*2){el.style.left=t.x+'px';el.style.top=t.y+'px';wi++;if(Math.random()<0.3){const fp=document.createElement('div');fp.className='footprint';fp.style.left=(t.x+10)+'px';fp.style.top=(t.y+34)+'px';hull.appendChild(fp);setTimeout(()=>fp.remove(),1500)}}else{el.style.left=(cx+dx/d*SPD)+'px';el.style.top=(cy+dy/d*SPD)+'px'}requestAnimationFrame(step)})()}
function dispatch(agent,task){const el=document.getElementById('crew-'+agent);if(!el)return;const b=el.querySelector('.bubble');if(b)b.textContent=task||'working...';const path=bfs(HOME_ROOM[agent]||agent,'ops');walkTo(el,path.map(r=>rc(r)),()=>{if(b)b.textContent=task;setTimeout(()=>{if(b)b.textContent='☕ done';const hp=bfs('ops',HOME_ROOM[agent]||agent);walkTo(el,hp.map(r=>rc(r)),()=>{el.classList.remove('working','walking');el.classList.add('idle');if(b)b.textContent=''})},10000)})}

// Spider bubble updates on ship
function updateSpiderBubble(spider, text){
    // Map spider names to crew element IDs
    const MAP={
        scholar:'crew-scholar',oracle:'crew-oracle',automator:'crew-automator',
        code_team:'room-code_team',cockpit:'room-cockpit',
    };
    // Try crew element first (has .bubble)
    const crewId=MAP[spider];
    if(!crewId)return;

    // For rooms (code_team, cockpit), find all crew elements inside
    let bubbles=[];
    const el=document.getElementById(crewId);
    if(!el)return;

    if(el.classList.contains('crew')){
        const b=el.querySelector('.bubble');
        if(b)bubbles=[b];
    } else {
        // Room — update all crew bubbles inside
        el.querySelectorAll('.crew .bubble').forEach(b=>bubbles.push(b));
    }

    // Truncate text to fit bubble
    const display=text.length>100?text.slice(0,97)+'...':text;
    bubbles.forEach(b=>{
        b.textContent=display;
        b.style.opacity='1';
        // Flash effect
        b.style.transition='none';
        b.style.background='rgba(196,30,58,0.15)';
        setTimeout(()=>{b.style.transition='all 0.3s';b.style.background='rgba(0,0,0,0.8)'},300);
    });

    // Auto-clear bubble after 10 seconds
    clearTimeout(el._bubbleTimer);
    el._bubbleTimer=setTimeout(()=>{
        bubbles.forEach(b=>{b.style.opacity='0'});
    },10000);
}

// Stats — HUD updater
let prevXP=0;
async function loadStats(flash){
    try{
        const[sr,ar]=await Promise.all([fetch(`${A}/api/game/stats`),fetch(`${A}/api/game/achievements`)]);
        const s=await sr.json();
        const achs=(await ar.json()).achievements;
        const p=s.next_level_total_xp>0?(s.xp_progress_in_level/(s.xp_progress_in_level+s.xp_to_next_level))*100:0;
        // Nav bar
        document.getElementById('n-lv').textContent=`Lv ${s.level}`;
        document.getElementById('n-xp').textContent=`${s.total_xp.toLocaleString()} XP`;
        document.getElementById('n-streak').textContent=`🔥 ${s.streak.current}`;
        document.getElementById('n-xp-bar').style.width=Math.min(100,p)+'%';
        // HUD level
        document.getElementById('hud-lv').textContent=s.level;
        document.getElementById('hud-rank').textContent=rank(s.level);
        // HUD XP
        document.getElementById('hud-xp-cur').textContent=s.total_xp.toLocaleString();
        document.getElementById('hud-xp-next').textContent=`→ Lv ${s.level+1}: ${s.next_level_total_xp.toLocaleString()}`;
        document.getElementById('hud-xp-bar').style.width=Math.min(100,p)+'%';
        // HUD stats
        document.getElementById('hud-streak').textContent=s.streak.current;
        const src=s.sources||{},loc=src.local||0,tot=loc+(src.cloud||0)+(src.system||0);
        document.getElementById('hud-local').textContent=tot>0?Math.round(loc/tot*100)+'%':'—';
        document.getElementById('hud-msgs').textContent=tot;
        // Ship systems
        document.getElementById('sys-hull').style.width=Math.min(100,p)+'%';
        document.getElementById('sys-shields').style.width=Math.min(100,(s.streak.current/30)*100)+'%';
        document.getElementById('sys-fuel').style.width=(tot>0?Math.round(loc/tot*100):0)+'%';
        // Achievements in HUD
        const unlocked=achs.filter(a=>a.unlocked);
        document.getElementById('hud-ach').innerHTML=unlocked.map(a=>`<div class="hud-badge">${a.icon} ${a.name}</div>`).join('');
        // Casino flash on XP gain
        if(flash && s.total_xp>prevXP){
            const el=document.getElementById('hud-level');el.classList.remove('flash');void el.offsetWidth;el.classList.add('flash');
        }
        prevXP=s.total_xp;
        return s;
    }catch(e){return null}
}

// Agents
async function loadAgents(){try{const r=await fetch(`${A}/api/agents`);const d=await r.json();let gm='';try{const s=await(await fetch(`${A}/api/agents/status`)).json();gm=s.gpu?.tracked_model||''}catch(e){}['scholar','automator','oracle'].forEach(n=>{const a=d.agents.find(x=>x.name===n);if(!a)return;const el=document.getElementById('rm-'+n);if(el)el.textContent=a.local_model;const pp=document.getElementById('rp-'+n);const act=gm&&a.local_model===gm;if(pp)pp.innerHTML=act?'<div class="pip on"></div><div class="pip on"></div><div class="pip on"></div>':'<div class="pip"></div><div class="pip"></div><div class="pip"></div>';const rm=document.getElementById('room-'+n);if(rm)rm.classList.toggle('active',act);const cr=document.getElementById('crew-'+n);if(cr){cr.classList.toggle('working',act);cr.classList.toggle('idle',!act)}})}catch(e){}}

// Models
async function loadModels(){try{const r=await fetch(`${A}/api/models`);const d=await r.json();document.getElementById('m-tbody').innerHTML=d.models.map(m=>{const gb=(m.size/1073741824).toFixed(1);const dt=m.details||{};return`<tr><td class="m-name">${m.name}</td><td>${gb} GB</td><td style="color:var(--dim)">${dt.family||'—'}</td><td style="color:var(--dim)">${dt.parameter_size||'—'}</td><td class="m-asgn">${m.assigned_to||'—'}</td><td><button class="m-btn" onclick="openM('${m.name}')">Assign</button></td></tr>`}).join('')}catch(e){}}
function openM(n){document.getElementById('asgn-m').value=n;document.getElementById('asgn-modal').classList.add('show')}
