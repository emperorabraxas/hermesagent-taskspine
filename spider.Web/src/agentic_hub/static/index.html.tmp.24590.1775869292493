<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Spider Web // スパイダーウェブ</title>
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;600;700&family=Space+Grotesk:wght@400;600;700&family=Noto+Sans+JP:wght@300;400;700&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{
    --bg:#080808;--bg2:#0e0e0e;--card:#111;--card-hover:#161616;
    --red:#c41e3a;--red-dim:rgba(196,30,58,0.12);--red-glow:rgba(196,30,58,0.25);
    --purple:#7b2d8b;--purple-dim:rgba(123,45,139,0.12);
    --bone:#e8e0d4;--white:#f0f0f0;--dim:#555;--dim2:#333;
    --green:#22c55e;--teal:#2dd4bf;--amber:#f59e0b;
    --border:rgba(196,30,58,0.1);--border2:rgba(255,255,255,0.04);
}
body{background:var(--bg);color:var(--bone);font-family:'JetBrains Mono',monospace;min-height:100vh;overflow:hidden}
::selection{background:var(--red);color:#fff}
::-webkit-scrollbar{width:3px}::-webkit-scrollbar-track{background:transparent}::-webkit-scrollbar-thumb{background:var(--red-dim);border-radius:2px}

/* === NAV === */
nav{
    height:44px;display:flex;align-items:center;padding:0 1rem;
    background:var(--bg);border-bottom:1px solid var(--border);
    position:relative;z-index:100;
}
nav::after{content:'';position:absolute;bottom:-1px;left:0;width:100%;height:1px;background:linear-gradient(90deg,transparent,var(--red),transparent)}
.n-brand{font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:1rem;color:var(--red);cursor:pointer}
.n-jp{font-family:'Noto Sans JP';font-size:0.5rem;color:var(--dim);margin-left:0.4rem;margin-right:auto}
.n-tabs{display:flex;gap:0}
.n-tab{
    padding:0.5rem 1rem;font-size:0.6rem;letter-spacing:2px;text-transform:uppercase;
    color:var(--dim);cursor:pointer;border-bottom:2px solid transparent;transition:all 0.2s;
    font-family:'Space Grotesk',sans-serif;
}
.n-tab:hover{color:var(--bone)}.n-tab.active{color:var(--red);border-bottom-color:var(--red)}
.n-stats{margin-left:auto;display:flex;align-items:center;gap:1rem;font-size:0.7rem}
.n-stats .lv{color:var(--red);font-weight:700;font-family:'Space Grotesk',sans-serif;font-size:0.85rem}
.n-stats .xp-wrap{display:flex;flex-direction:column;gap:2px;align-items:flex-end}
.n-stats .xp-text{font-size:0.6rem;color:var(--bone);font-weight:600}
.n-stats .xp-bar{width:100px;height:5px;background:var(--dim2);border-radius:2px;overflow:hidden}
.n-stats .xp-fill{height:100%;background:linear-gradient(90deg,var(--red),var(--purple));border-radius:2px;transition:width 0.8s;box-shadow:0 0 6px var(--red-glow)}
.n-stats .streak{color:var(--amber);font-size:0.75rem;font-weight:600}

/* === LAYOUT === */
.view{display:none;height:calc(100vh - 44px)}.view.active{display:flex;flex-direction:column}
#v-settings.active{display:block}

/* === BRIDGE (Ship + Chat) === */
#v-bridge.active{display:flex;flex-direction:column;margin-right:260px}
.ship-panel{
    height:300px;flex-shrink:0;position:relative;overflow:hidden;
    background:radial-gradient(ellipse at 50% 50%,#0c0c0c,#040404);
    border-bottom:1px solid var(--border);
}
.ship-panel .stars{position:absolute;inset:0}
.star{position:absolute;width:1.5px;height:1.5px;background:rgba(255,255,255,0.4);border-radius:50%;animation:tw 4s ease-in-out infinite alternate}
@keyframes tw{0%{opacity:0.1}100%{opacity:0.6}}

/* Ship hull */
.hull{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%) scale(0.78);width:720px;height:320px}
.hull-bg{position:absolute;inset:0;background:transparent}
/* SVG silk strands */
.corr-svg{position:absolute;inset:0;pointer-events:none;z-index:1}
.corr-glow{stroke:rgba(196,30,58,0.08);stroke-width:8;stroke-linecap:round;fill:none}
.corr-main{stroke:rgba(196,30,58,0.5);stroke-width:1.5;fill:none}
.corr-wall{stroke:rgba(196,30,58,0.15);stroke-width:0.5;fill:none}
.web-ring{fill:none;stroke:rgba(196,30,58,0.18);stroke-width:0.8}
.web-radial{stroke:rgba(196,30,58,0.12);stroke-width:0.5;fill:none}

/* Ship rooms */
.s-room{
    position:absolute;border:2px solid rgba(196,30,58,0.2);
    background:rgba(15,15,18,0.85);z-index:2;transition:all 0.3s;overflow:hidden;
}
.s-room:hover{border-color:rgba(196,30,58,0.4)}
.s-room.active{border-color:rgba(34,197,94,0.5);box-shadow:0 0 20px rgba(34,197,94,0.05)}
/* Floor tiles per room */
.s-room .floor{position:absolute;inset:0;opacity:0.12;pointer-events:none;
    background-size:16px 16px;
    background-image:linear-gradient(rgba(255,255,255,0.05) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,0.05) 1px,transparent 1px)}
.s-room.fl-teal .floor{background-color:rgba(45,212,191,0.15)}
.s-room.fl-purple .floor{background-color:rgba(123,45,139,0.15)}
.s-room.fl-amber .floor{background-color:rgba(245,158,11,0.15)}
.s-room.fl-red .floor{background-color:rgba(196,30,58,0.15)}
.s-room.fl-green .floor{background-color:rgba(34,197,94,0.12)}
/* Furniture items */
.furn{position:absolute;font-size:0.65rem;opacity:0.5;pointer-events:none;filter:drop-shadow(0 1px 2px rgba(0,0,0,0.5))}
.furn.big{font-size:0.85rem}
.furn.sm{font-size:0.5rem;opacity:0.35}
.s-room .r-name{position:absolute;top:5px;left:7px;font-size:0.5rem;font-family:'Space Grotesk',sans-serif;font-weight:700;letter-spacing:1.5px;text-transform:uppercase}
.s-room .r-jp{position:absolute;top:4px;right:6px;font-family:'Noto Sans JP';font-size:0.5rem;color:var(--dim2)}
.s-room .r-model{position:absolute;bottom:4px;left:7px;font-size:0.45rem;color:var(--dim)}
.s-room .r-pips{position:absolute;bottom:5px;right:6px;display:flex;gap:2px}
.pip{width:5px;height:8px;border:1px solid var(--dim2);border-radius:1px}
.pip.on{background:var(--green);border-color:var(--green);box-shadow:0 0 3px var(--green)}

/* Edit mode */
.s-room.draggable{cursor:grab}.s-room.dragging{opacity:0.7;z-index:50;box-shadow:0 0 30px var(--red-glow)}
.edit-on .s-room{border-style:dashed}
.edit-grid{position:absolute;inset:0;display:none;pointer-events:none;background:repeating-linear-gradient(90deg,rgba(196,30,58,0.03) 0px,transparent 1px,transparent 20px),repeating-linear-gradient(0deg,rgba(196,30,58,0.03) 0px,transparent 1px,transparent 20px)}
.edit-on .edit-grid{display:block}
.ship-bar{position:absolute;top:6px;left:6px;z-index:60;display:flex;gap:0.4rem}
.s-btn{background:rgba(0,0,0,0.7);border:1px solid var(--border);color:var(--dim);padding:0.25rem 0.6rem;font-size:0.55rem;cursor:pointer;font-family:'Space Grotesk';text-transform:uppercase;letter-spacing:1px;transition:all 0.2s}
.s-btn:hover{color:var(--red);border-color:var(--red)}.s-btn.on{color:var(--red);border-color:var(--red);background:var(--red-dim)}

/* === HUD PANEL (gamification + systems) === */
.hud{position:fixed;top:44px;right:0;width:260px;height:calc(100vh - 44px);background:rgba(6,6,8,0.95);border-left:1px solid var(--border);padding:1rem;z-index:10;backdrop-filter:blur(10px);display:flex;flex-direction:column;gap:0.7rem;overflow-y:auto}
.hud::before{content:'';position:absolute;top:0;left:10px;right:10px;height:1px;background:linear-gradient(90deg,transparent,var(--red),transparent)}
/* Level hero */
.hud-level{text-align:center;padding:0.2rem 0}
.hud-level .h-rank{font-family:'Noto Sans JP','Space Grotesk';font-size:0.6rem;letter-spacing:2px;color:var(--purple);text-transform:uppercase}
.hud-level .h-lv{font-family:'Space Grotesk';font-size:4.5rem;font-weight:700;color:var(--red);line-height:1;text-shadow:0 0 50px rgba(196,30,58,0.4)}
.hud-level .h-lbl{font-size:0.5rem;color:var(--dim);text-transform:uppercase;letter-spacing:3px}
/* XP bar */
.hud-xp{display:flex;flex-direction:column;gap:2px}
.hud-xp .hx-text{display:flex;justify-content:space-between;font-size:0.55rem;color:var(--dim)}
.hud-xp .hx-text b{color:var(--bone);font-size:0.65rem}
.hud-xp .hx-bar{height:10px;background:var(--dim2);border-radius:3px;overflow:hidden;border:1px solid rgba(196,30,58,0.1)}
.hud-xp .hx-fill{height:100%;border-radius:2px;background:linear-gradient(90deg,var(--red),var(--purple));transition:width 1s cubic-bezier(0.4,0,0.2,1);box-shadow:0 0 10px var(--red-glow)}
/* Stats row */
.hud-stats{display:flex;justify-content:space-between;gap:0.3rem;padding:0.3rem 0}
.hud-stat{text-align:center;flex:1;padding:0.4rem 0;background:rgba(255,255,255,0.015);border:1px solid var(--border);border-radius:3px}
.hud-stat .hs-val{font-family:'Space Grotesk';font-size:1.2rem;font-weight:700}
.hud-stat .hs-lbl{font-size:0.4rem;color:var(--dim);text-transform:uppercase;letter-spacing:1px;margin-top:0.1rem}
.hs-val.fire{color:var(--amber)}.hs-val.loc{color:var(--teal)}.hs-val.msg{color:var(--bone)}
/* Systems */
.hud-sys{border-top:1px solid var(--border);padding-top:0.5rem}
.hud-sys .hs-title{font-family:'Space Grotesk';font-size:0.5rem;text-transform:uppercase;letter-spacing:2px;color:var(--red);margin-bottom:0.35rem}
.sp-row{display:flex;align-items:center;gap:0.4rem;padding:0.15rem 0;font-size:0.55rem}
.sp-row span{flex:1;color:var(--dim)}
.sp-bar{flex:2;height:6px;background:var(--dim2);border-radius:2px;overflow:hidden}
.sp-fill{height:100%;border-radius:1px;transition:width 0.5s}
.sp-fill.red{background:var(--red)}.sp-fill.grn{background:var(--green)}.sp-fill.teal{background:var(--teal)}.sp-fill.amb{background:var(--amber)}
/* Achievement popup */
.hud-ach{border-top:1px solid var(--border);padding-top:0.3rem;display:flex;flex-wrap:wrap;gap:0.25rem}
/* Conversations list */
.hud-convos{border-top:1px solid var(--border);padding-top:0.5rem;margin-top:0.3rem;flex:1;min-height:0;display:flex;flex-direction:column}
.hud-convos .hc-title{font-family:'Space Grotesk';font-size:0.5rem;text-transform:uppercase;letter-spacing:2px;color:var(--red);margin-bottom:0.4rem;display:flex;justify-content:space-between;align-items:center}
.hud-convos .hc-new{background:none;border:1px solid var(--border2);color:var(--dim);padding:0.1rem 0.4rem;border-radius:2px;font-size:0.5rem;cursor:pointer;font-family:'Space Grotesk';letter-spacing:1px}
.hud-convos .hc-new:hover{color:var(--red);border-color:var(--red)}
.hud-convos .hc-list{overflow-y:auto;flex:1;display:flex;flex-direction:column;gap:0.2rem}
.conv-item{padding:0.35rem 0.5rem;border-radius:3px;cursor:pointer;font-size:0.6rem;color:var(--dim);border:1px solid transparent;transition:all 0.2s;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.conv-item:hover{background:rgba(196,30,58,0.05);border-color:var(--border);color:var(--bone)}
.conv-item.active{background:var(--red-dim);border-color:rgba(196,30,58,0.2);color:var(--bone)}
.conv-item .ci-time{font-size:0.45rem;color:var(--dim2);margin-left:0.3rem}
.hud-badge{font-size:0.6rem;padding:0.25rem 0.5rem;background:var(--red-dim);border:1px solid rgba(196,30,58,0.25);border-radius:3px;display:flex;align-items:center;gap:0.25rem;animation:badgePop 0.5s ease}
@keyframes badgePop{0%{transform:scale(0.5);opacity:0}100%{transform:scale(1);opacity:1}}
/* XP flash animation on earn */
.hud-level.flash .h-lv{animation:xpFlash 0.6s ease}
@keyframes xpFlash{0%{transform:scale(1)}30%{transform:scale(1.2);text-shadow:0 0 40px rgba(196,30,58,0.6)}100%{transform:scale(1)}}
.ship-name{position:absolute;bottom:6px;left:50%;transform:translateX(-50%);font-size:0.5rem;color:var(--dim2);letter-spacing:3px;text-transform:uppercase;font-family:'Space Grotesk'}
.ship-name b{color:var(--red)}

/* Crew characters */
.crew{position:absolute;display:flex;flex-direction:column;align-items:center;z-index:5;transition:all 0.3s}
.crew .bubble{
    position:absolute;top:-38px;left:50%;transform:translateX(-50%);
    font-size:0.6rem;background:rgba(8,8,8,0.92);color:var(--bone);
    padding:0.35rem 0.6rem;border-radius:6px;white-space:nowrap;opacity:0;transition:all 0.3s;
    border:1px solid rgba(196,30,58,0.25);max-width:220px;overflow:hidden;text-overflow:ellipsis;
    box-shadow:0 2px 12px rgba(0,0,0,0.5);z-index:20;
    backdrop-filter:blur(6px);
}
/* Bubble opacity controlled by JS updateSpiderBubble */
/* Spider pixel art body */
.c-body{position:relative;width:28px;height:24px}
/* Abdomen (big back circle) */
.c-body .torso{position:absolute;bottom:0;left:50%;transform:translateX(-50%);width:14px;height:12px;border-radius:50%;background:currentColor}
/* Head (smaller front circle) */
.c-body .head{position:absolute;top:0;left:50%;transform:translateX(-50%);width:10px;height:9px;border-radius:50%;border:none;background:currentColor}
/* Eyes (4 spider eyes in 2 rows) */
.c-body .eyes{position:absolute;top:2px;left:50%;transform:translateX(-50%);display:grid;grid-template-columns:1fr 1fr;gap:1px}
.c-body .eye{width:2px;height:2px;border-radius:50%;background:#fff}
/* 8 spider legs — 4 per side */
.c-body .legs{display:none}
.c-body .leg{display:none}
.c-body .arm-l,.c-body .arm-r{display:none}
.spider-legs{position:absolute;top:6px;left:50%;transform:translateX(-50%);width:28px;height:16px}
.s-leg{position:absolute;width:8px;height:1.5px;background:currentColor;transform-origin:0% 50%;border-radius:1px}
/* Left legs */
.s-leg.l1{top:1px;left:2px;transform:rotate(-30deg)}.s-leg.l2{top:5px;left:0;transform:rotate(-15deg)}
.s-leg.l3{top:9px;left:0;transform:rotate(10deg)}.s-leg.l4{top:13px;left:2px;transform:rotate(25deg)}
/* Right legs */
.s-leg.r1{top:1px;right:2px;transform:rotate(30deg);transform-origin:100% 50%}
.s-leg.r2{top:5px;right:0;transform:rotate(15deg);transform-origin:100% 50%}
.s-leg.r3{top:9px;right:0;transform:rotate(-10deg);transform-origin:100% 50%}
.s-leg.r4{top:13px;right:2px;transform:rotate(-25deg);transform-origin:100% 50%}
.c-body .badge{position:absolute;top:-6px;left:50%;transform:translateX(-50%);font-size:0.4rem;z-index:2}
.c-tag{font-size:0.4rem;color:var(--dim);margin-top:1px;font-family:'Space Grotesk';text-transform:uppercase;letter-spacing:0.5px}
.c-shadow{width:16px;height:3px;border-radius:50%;background:rgba(0,0,0,0.25);margin-top:-1px}

/* Crew color themes */
/* Spider colors — uses currentColor for body + legs */
.cr-opus{color:var(--red)}.cr-scholar{color:var(--teal)}.cr-oracle{color:var(--purple)}.cr-auto{color:var(--amber)}.cr-codex{color:var(--green)}

/* Animations */
.crew.idle{animation:cIdle 3.5s ease-in-out infinite}
@keyframes cIdle{0%,100%{transform:translateY(0)}50%{transform:translateY(-2px)}}
.crew.working{animation:cWork 0.6s ease-in-out infinite}
@keyframes cWork{0%,100%{transform:translateY(0) scale(1)}50%{transform:translateY(-4px) scale(1.06)}}
/* Spider leg animations */
.crew.working .head{box-shadow:0 0 6px currentColor}
.crew.working .s-leg{animation:legTwitch 0.4s ease-in-out infinite alternate}
.crew.working .s-leg.l2,.crew.working .s-leg.r2{animation-delay:0.1s}
.crew.working .s-leg.l3,.crew.working .s-leg.r3{animation-delay:0.2s}
.crew.working .s-leg.l4,.crew.working .s-leg.r4{animation-delay:0.3s}
@keyframes legTwitch{0%{transform:rotate(var(--base-rot,0deg))}100%{transform:rotate(calc(var(--base-rot,0deg) + 8deg))}}
.crew.walking{animation:none}
.crew.walking .s-leg{animation:legWalk 0.25s ease-in-out infinite alternate}
.crew.walking .s-leg.l2,.crew.walking .s-leg.r1{animation-delay:0.06s}
.crew.walking .s-leg.l3,.crew.walking .s-leg.r2{animation-delay:0.12s}
.crew.walking .s-leg.l4,.crew.walking .s-leg.r3{animation-delay:0.18s}
@keyframes legWalk{0%{transform:rotate(var(--base-rot,0deg))}100%{transform:rotate(calc(var(--base-rot,0deg) + 15deg))}}
.footprint{position:absolute;width:3px;height:3px;border-radius:50%;background:rgba(196,30,58,0.12);pointer-events:none;animation:fpFade 1.5s ease-out forwards}
@keyframes fpFade{to{opacity:0;transform:scale(0.2)}}

/* === CHAT === */
.chat-panel{flex:1;display:flex;flex-direction:column;min-height:0;padding:0.75rem 1rem 0.5rem}
.chat-msgs{flex:1;overflow-y:auto;display:flex;flex-direction:column;gap:0.5rem;padding:0.5rem 0}
.msg{max-width:80%;padding:0.65rem 0.85rem;font-size:0.78rem;line-height:1.6;animation:fadeIn 0.3s ease;border-left:2px solid transparent}
@keyframes fadeIn{from{opacity:0;transform:translateY(4px)}to{opacity:1;transform:none}}
.msg.user{align-self:flex-end;background:rgba(196,30,58,0.05);border:1px solid var(--red-dim);border-right:2px solid var(--red);border-left:none;border-radius:4px 2px 2px 4px}
.msg.assistant{align-self:flex-start;background:rgba(255,255,255,0.01);border:1px solid var(--border2);border-left:2px solid var(--dim2);border-radius:2px 4px 4px 2px}
.msg .tag{font-size:0.5rem;text-transform:uppercase;letter-spacing:2px;margin-bottom:0.25rem;font-weight:700;font-family:'Space Grotesk'}
.tag.scholar{color:var(--teal)}.tag.oracle{color:var(--purple)}.tag.automator{color:var(--amber)}.tag.code_team{color:var(--red)}.tag.opus{color:var(--red)}.tag.system{color:var(--dim)}
.msg pre{background:rgba(0,0,0,0.4);padding:0.5rem 0.7rem;border-radius:2px;overflow-x:auto;margin:0.4rem 0;font-size:0.72rem;border-left:2px solid var(--red)}
.msg code:not(pre code){background:rgba(196,30,58,0.06);padding:0.1em 0.3em;border-radius:2px;font-size:0.8em;color:var(--red)}
.msg strong{color:var(--white)}.msg h2,.msg h3,.msg h4{color:var(--red);font-family:'Space Grotesk';margin:0.5em 0 0.2em}.msg h2{font-size:0.95rem}.msg h3{font-size:0.85rem}.msg h4{font-size:0.8rem}
/* Typing dots */
.typing-dots{color:var(--dim);font-size:1.2rem;letter-spacing:3px}
.typing-dots span{animation:dotBlink 1.4s infinite;opacity:0.2}
.typing-dots span:nth-child(2){animation-delay:0.2s}
.typing-dots span:nth-child(3){animation-delay:0.4s}
@keyframes dotBlink{0%,100%{opacity:0.2}50%{opacity:1}}
.xp-toast{font-size:0.6rem;margin-top:0.35rem;padding:0.2rem 0.5rem;display:inline-block;background:rgba(34,197,94,0.06);border:1px solid rgba(34,197,94,0.15);color:var(--green);border-radius:2px}
.ach-toast{font-size:0.6rem;margin-top:0.2rem;padding:0.2rem 0.5rem;display:inline-block;background:rgba(196,30,58,0.06);border:1px solid var(--red-dim);color:var(--red);border-radius:2px;animation:achGlow 1.5s ease 3}
@keyframes achGlow{50%{box-shadow:0 0 12px var(--red-glow)}}

/* Level up celebration */
.level-up-flash{animation:lvlFlash 0.8s ease}
@keyframes lvlFlash{0%{filter:brightness(1)}20%{filter:brightness(2.5)}100%{filter:brightness(1)}}
.screen-shake{animation:shake 0.4s ease}
@keyframes shake{0%,100%{transform:translateX(0)}20%{transform:translateX(-4px)}40%{transform:translateX(4px)}60%{transform:translateX(-3px)}80%{transform:translateX(2px)}}

/* Combo indicator */
.combo-badge{
    position:fixed;top:50px;left:50%;transform:translateX(-50%);z-index:200;
    font-family:'Space Grotesk';font-weight:700;font-size:1.2rem;color:var(--red);
    background:rgba(8,8,8,0.9);border:1px solid var(--red);padding:0.3rem 1rem;
    border-radius:4px;opacity:0;transition:all 0.3s;pointer-events:none;
    box-shadow:0 0 20px var(--red-glow);
}
.combo-badge.show{opacity:1;transform:translateX(-50%) scale(1.1)}

/* Room loading pulse */
.s-room.loading{animation:roomPulse 1.5s ease-in-out infinite}
@keyframes roomPulse{0%,100%{box-shadow:none}50%{box-shadow:0 0 20px rgba(196,30,58,0.2)}}

/* Chat header */
.chat-header{display:flex;align-items:center;justify-content:space-between;padding:0.4rem 0;border-bottom:1px solid var(--border2)}
.new-chat-btn{background:none;border:1px solid var(--border2);color:var(--dim);padding:0.2rem 0.6rem;border-radius:3px;font-size:0.55rem;cursor:pointer;font-family:'Space Grotesk';letter-spacing:1px;transition:all 0.2s}
.new-chat-btn:hover{color:var(--red);border-color:var(--red)}
/* Copy code button */
.msg pre{position:relative}
.copy-btn{position:absolute;top:4px;right:4px;background:rgba(196,30,58,0.15);border:1px solid var(--border);color:var(--dim);padding:0.15rem 0.4rem;border-radius:2px;font-size:0.5rem;cursor:pointer;font-family:'JetBrains Mono';opacity:0;transition:opacity 0.2s}
.msg pre:hover .copy-btn{opacity:1}
.copy-btn.copied{color:var(--green);border-color:var(--green)}
/* Error retry */
.retry-btn{background:var(--red-dim);border:1px solid var(--red);color:var(--red);padding:0.25rem 0.8rem;border-radius:3px;font-size:0.6rem;cursor:pointer;font-family:'Space Grotesk';margin-top:0.5rem;display:inline-block}
.retry-btn:hover{background:var(--red);color:#fff}
.chat-bar{display:flex;gap:0.4rem;padding:0.5rem 0;border-top:1px solid var(--border)}
.chat-bar input{flex:1;background:var(--bg2);border:1px solid var(--border2);border-radius:2px;padding:0.6rem 0.8rem;color:var(--bone);font-family:'JetBrains Mono';font-size:0.78rem;outline:none;transition:border-color 0.2s}
.chat-bar input:focus{border-color:var(--red)}
.chat-bar input::placeholder{color:var(--dim2)}
.chat-bar button{background:var(--red);border:none;color:#fff;padding:0.6rem 1.2rem;border-radius:2px;font-family:'Space Grotesk';font-weight:700;font-size:0.78rem;cursor:pointer;transition:all 0.2s;letter-spacing:1px}
.chat-bar button:hover{box-shadow:0 0 20px var(--red-glow)}.chat-bar button:disabled{opacity:0.3;cursor:not-allowed}

/* === OTHER PAGES === */
.page{display:none;padding:1.2rem;max-width:1000px;margin:0 auto;height:calc(100vh - 44px);overflow-y:auto}.page.active{display:block}
.sec-t{font-family:'Space Grotesk';font-size:1.1rem;font-weight:700;color:var(--red);margin-bottom:0.2rem}
.sec-s{font-size:0.55rem;color:var(--dim);margin-bottom:1.2rem;letter-spacing:1px;font-family:'Noto Sans JP'}

/* Models table */
.m-table{width:100%;border-collapse:collapse}.m-table th{text-align:left;padding:0.5rem 0.8rem;font-size:0.5rem;text-transform:uppercase;letter-spacing:2px;color:var(--dim);border-bottom:1px solid var(--border);font-family:'Space Grotesk'}
.m-table td{padding:0.55rem 0.8rem;font-size:0.72rem;border-bottom:1px solid var(--border2)}
.m-table tr:hover td{background:var(--red-dim)}
.m-name{color:var(--teal);font-weight:600}.m-asgn{color:var(--red)}
.m-btn{background:none;border:1px solid var(--border2);color:var(--dim);padding:0.2rem 0.5rem;border-radius:2px;font-size:0.6rem;cursor:pointer;font-family:'JetBrains Mono';transition:all 0.2s}
.m-btn:hover{border-color:var(--red);color:var(--red)}

/* Stats page */
.st-hero{text-align:center;padding:2rem 0 1rem}
.st-hero .rank{font-family:'Noto Sans JP','Space Grotesk';font-size:0.6rem;letter-spacing:3px;color:var(--purple)}
.st-hero .lvl{font-family:'Space Grotesk';font-size:5rem;font-weight:700;color:var(--red);text-shadow:0 0 60px rgba(196,30,58,0.15);line-height:1}
.st-hero .lbl{font-size:0.5rem;color:var(--dim);text-transform:uppercase;letter-spacing:3px;margin-top:0.2rem}
.st-hero .xp{font-size:1.2rem;color:var(--bone);margin-top:0.4rem}.st-hero .xp b{color:var(--red)}
.st-bar{max-width:400px;margin:1rem auto}.st-bar-out{height:12px;background:var(--dim2);border-radius:2px;overflow:hidden;border:1px solid var(--border2)}
.st-bar-in{height:100%;background:linear-gradient(90deg,var(--red),var(--purple));transition:width 1.5s;box-shadow:0 0 10px var(--red-glow)}
.st-bar-lbl{display:flex;justify-content:space-between;font-size:0.55rem;color:var(--dim);margin-top:0.3rem}
.st-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:0.8rem;margin:1.5rem 0}
.st-card{background:var(--card);border:1px solid var(--border2);padding:1rem;text-align:center}
.st-card .v{font-size:1.8rem;font-weight:700;font-family:'Space Grotesk'}.st-card .l{font-size:0.5rem;color:var(--dim);text-transform:uppercase;letter-spacing:1.5px;margin-top:0.15rem}
.st-card.c-red .v{color:var(--red)}.st-card.c-grn .v{color:var(--green)}.st-card.c-amb .v{color:var(--amber)}.st-card.c-pur .v{color:var(--purple)}
.badge-row{display:flex;flex-wrap:wrap;gap:0.4rem;margin-top:0.8rem}
.bdg{padding:0.35rem 0.65rem;font-size:0.65rem;border:1px solid var(--border2);background:var(--card);display:flex;align-items:center;gap:0.3rem;transition:all 0.3s}
.bdg.on{border-color:var(--red-dim);background:var(--red-dim)}.bdg.off{opacity:0.15}

/* Modal */
.modal-bg{position:fixed;inset:0;background:rgba(0,0,0,0.8);z-index:200;display:none;align-items:center;justify-content:center;backdrop-filter:blur(4px)}
