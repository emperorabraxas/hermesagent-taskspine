function sfxCombo(){}

// ===== COMBO SYSTEM =====
let lastMsgTime=0,comboCount=0,comboTimer=null;
function updateCombo(){
    const now=Date.now();
    if(now-lastMsgTime<60000&&lastMsgTime>0){
        comboCount++;
        if(comboCount>=2){
            const badge=document.getElementById('combo-badge');
            const mult=comboCount>=5?'3x':comboCount>=3?'2x':'1.5x';
            badge.textContent=`🔥 ${mult} COMBO (${comboCount})`;
            badge.classList.add('show');
            sfxCombo();
            clearTimeout(comboTimer);
            comboTimer=setTimeout(()=>{badge.classList.remove('show');comboCount=0},3000);
        }
    }else{comboCount=1}
    lastMsgTime=now;
}

// ===== LEVEL UP DETECTION =====
let prevLevel=0;
function checkLevelUp(newLevel){
    if(newLevel>prevLevel&&prevLevel>0){
        // LEVEL UP!
        sfxLevelUp();
        document.body.classList.add('screen-shake');
        document.getElementById('hud')?.classList.add('level-up-flash');
        setTimeout(()=>{document.body.classList.remove('screen-shake');document.getElementById('hud')?.classList.remove('level-up-flash')},800);
    }
    prevLevel=newLevel;
}

// ===== FIRST-LAUNCH SETUP =====
async function checkSetup(){
    try{
        const r=await fetch(`${A}/api/config`);
        const d=await r.json();
        if(!d.has_anthropic&&!localStorage.getItem('sw-setup-skipped')){
            document.getElementById('setup-modal').classList.add('show');
        }
    }catch(e){}
}
function closeSetup(){
    document.getElementById('setup-modal').classList.remove('show');
    localStorage.setItem('sw-setup-skipped','1');
}
async function saveSetup(){
    const ak=document.getElementById('setup-anthropic').value.trim();
    const ok=document.getElementById('setup-openai').value.trim();
    if(!ak&&!ok){closeSetup();return}
    try{
        await fetch(`${A}/api/config/keys`,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({anthropic_key:ak,openai_key:ok})});
        document.getElementById('setup-modal').classList.remove('show');
        // Show restart notice
        const msgs=document.getElementById('chat-msgs');
        msgs.innerHTML+='<div class="msg assistant"><div class="tag system">setup</div><div class="msg-body">Keys saved. <strong>Restart the server</strong> to enable Opus validation: <code>hub serve</code></div></div>';
    }catch(e){alert('Failed to save: '+e.message)}
}

