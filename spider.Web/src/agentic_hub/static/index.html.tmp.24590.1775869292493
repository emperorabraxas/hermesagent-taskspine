async function doAsgn(){const m=document.getElementById('asgn-m').value,a=document.getElementById('asgn-a').value;await fetch(`${A}/api/models/assign`,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({model:m,agent:a})});closeM();loadModels();loadAgents()}

// Chat — SSE streaming
async function send(){
    const inp=document.getElementById('chat-in'),btn=document.getElementById('send-btn');
    const msg=inp.value.trim();if(!msg)return;
    inp.value='';btn.disabled=true;
    addM('user',msg);
    const ae=addM('assistant','<span class="typing-dots"><span>.</span><span>.</span><span>.</span></span>');
    const bd=ae.querySelector('.msg-body');
    const tg=ae.querySelector('.tag');
    let rawText='',agent='',dispatched=false;

    try{
        const params=new URLSearchParams({message:msg});
        if(sid)params.set('session_id',sid);
        const resp=await fetch(`${A}/api/chat/stream?${params}`);
        const reader=resp.body.getReader();
        const decoder=new TextDecoder();
        let buf='',curEvent='';

        while(true){
            const{done,value}=await reader.read();
            if(done)break;
            buf+=decoder.decode(value,{stream:true});
            const lines=buf.split('\n');
            buf=lines.pop()||'';

            for(const line of lines){
                if(line.startsWith('event:')){curEvent=line.slice(6).trim();continue}
                if(!line.startsWith('data:'))continue;
                let data;try{data=JSON.parse(line.slice(5).trim())}catch(e){continue}

                if(curEvent==='spider'){
                    const spider=data.spider;
                    const text=data.text;
                    updateSpiderBubble(spider,text);
                    // Pulse room while loading
                    const roomEl=document.getElementById('room-'+spider);
                    if(roomEl){
                        if(text.includes('Loading')||text.includes('⏳')){
                            roomEl.classList.add('loading');
                        }else{
                            roomEl.classList.remove('loading');
                        }
                    }
                    continue;
                }
                if(curEvent==='token'){
                    const chunk=data.text||'';
                    if(!sid)sid=data.session_id;

                    // Detect agent from routing tag *[agent · mode]*
                    if(rawText.length<5 && chunk.startsWith('*[')){
                        const full=chunk;
                        const end=full.indexOf(']*');
                        if(end>0){
                            agent=full.substring(2,end).split('·')[0].trim();
                            tg.textContent=agent;
                            tg.className='tag '+agent.replace(/\s/g,'_').toLowerCase();
                            // Dispatch spider to Ops Center
                            const TH={scholar:'📚 researching...',oracle:'🍵 thinking...',automator:'⚙️ executing...',code_team:'💻 coding...'};
                            if(!dispatched&&TH[agent]){dispatch(agent,TH[agent]);dispatched=true}
                            rawText+=chunk;
                            continue; // Don't render the routing tag
                        }
                    }

                    rawText+=chunk;
                    // Strip routing tag from display
                    let display=rawText;
                    if(display.startsWith('*[')){
                        const tagEnd=display.indexOf(']*\n');
                        if(tagEnd>0)display=display.substring(tagEnd+3);
                    }
                    bd.innerHTML=fmt(display);
                    scr();
                }
                else if(curEvent==='done'){
                    sid=data.session_id;
                    // XP toast + sound
                    const xp=data.xp;
                    if(xp&&xp.xp_earned){
                        const ml=xp.multiplier>1?` (${xp.multiplier}x)`:'';
                        bd.innerHTML+=`<div class="xp-toast">+${xp.xp_earned} XP${ml} · Lv ${xp.level} · ${xp.total_xp.toLocaleString()}</div>`;
                        sfxXP();
                        checkLevelUp(xp.level);
                        updateCombo();
                    }
                    // Achievement toasts + sound
                    if(data.achievements&&data.achievements.length>0){
                        for(const a of data.achievements)
                            bd.innerHTML+=`<div class="ach-toast">${a.icon} ${a.name}</div>`;
                        sfxAchievement();
                    }

                    loadStats(true);loadAgents();
                }
            }
        }
        saveChat();
    }catch(e){
        bd.innerHTML=`<span style="color:var(--red)">Error: ${e.message}</span><br><button class="retry-btn" onclick="this.parentElement.parentElement.remove();document.getElementById('chat-in').value='${msg.replace(/'/g,"\\'")}';send()">Retry</button>`;
    }
    btn.disabled=false;inp.focus();scr();
}
function addM(r,h){const b=document.getElementById('chat-msgs');const e=document.createElement('div');e.className='msg '+r;e.innerHTML=r==='assistant'?`<div class="tag"></div><div class="msg-body">${h}</div>`:`<div class="msg-body">${h}</div>`;b.appendChild(e);scr();return e}
function scr(){const b=document.getElementById('chat-msgs');requestAnimationFrame(()=>b.scrollTop=b.scrollHeight)}
function fmt(t){
    return t
        .replace(/!\[([^\]]*)\]\(([^)]+)\)/g,'<img src="$2" alt="$1" style="max-width:100%;border-radius:4px;margin:0.5rem 0;border:1px solid var(--border)" />')
        .replace(/```(\w*)\n([\s\S]*?)```/g,(m,lang,code)=>{
            const escaped=code.replace(/</g,'&lt;').replace(/>/g,'&gt;');
            const id='cp'+Math.random().toString(36).slice(2,8);
            return `<pre><button class="copy-btn" onclick="copyCode(this,'${id}')" id="${id}">Copy</button><code>${escaped}</code></pre>`;
        })
        .replace(/`([^`]+)`/g,'<code>$1</code>')
        .replace(/\*\*(.+?)\*\*/g,'<strong>$1</strong>')
        .replace(/\*(.+?)\*/g,'<em>$1</em>')
        .replace(/^#### (.+)$/gm,'<h4>$1</h4>')
        .replace(/^### (.+)$/gm,'<h3>$1</h3>')
        .replace(/^## (.+)$/gm,'<h2>$1</h2>')
        .replace(/^- (.+)$/gm,'<div style="padding-left:1em">• $1</div>')
        .replace(/\n\n/g,'<br><br>').replace(/\n/g,'<br>');
}
function copyCode(btn,id){
    const pre=btn.parentElement;
    const code=pre.querySelector('code').textContent;
    navigator.clipboard.writeText(code).then(()=>{
        btn.textContent='Copied!';btn.classList.add('copied');
        setTimeout(()=>{btn.textContent='Copy';btn.classList.remove('copied')},1500);
    });
}

// ===== CONVERSATION MANAGEMENT =====
let convos=JSON.parse(localStorage.getItem('sw-convos')||'[]');
let activeConvo=localStorage.getItem('sw-active-convo')||null;

function saveChat(){
    const msgs=document.getElementById('chat-msgs');
    const html=msgs.innerHTML;
    if(!activeConvo){
        // Create new conversation entry
        activeConvo='c_'+Date.now();
        // Auto-title from first user message
        const firstMsg=msgs.querySelector('.msg.user .msg-body');
        const title=firstMsg?firstMsg.textContent.slice(0,40):'New conversation';
        convos.unshift({id:activeConvo, title, time:Date.now(), sid:sid});
    }
    // Update existing convo
    const c=convos.find(x=>x.id===activeConvo);
    if(c){c.sid=sid;c.time=Date.now()}
    localStorage.setItem('sw-convo-'+activeConvo, html);
    localStorage.setItem('sw-convos', JSON.stringify(convos));
    localStorage.setItem('sw-active-convo', activeConvo);
    renderConvoList();
}

function loadChat(){
    activeConvo=localStorage.getItem('sw-active-convo')||null;
    if(activeConvo){
        const html=localStorage.getItem('sw-convo-'+activeConvo);
        if(html) document.getElementById('chat-msgs').innerHTML=html;
        const c=convos.find(x=>x.id===activeConvo);
        if(c&&c.sid) sid=c.sid;
    }
    renderConvoList();
}

function switchConvo(id){
    // Save current first
    if(activeConvo){
        localStorage.setItem('sw-convo-'+activeConvo, document.getElementById('chat-msgs').innerHTML);
    }
    activeConvo=id;
    localStorage.setItem('sw-active-convo', id);
    const html=localStorage.getItem('sw-convo-'+id);
    if(html) document.getElementById('chat-msgs').innerHTML=html;
    const c=convos.find(x=>x.id===id);
    sid=c?.sid||null;
    renderConvoList();
    scr();
}

function newConvo(){
    // Save current
    if(activeConvo){
        localStorage.setItem('sw-convo-'+activeConvo, document.getElementById('chat-msgs').innerHTML);
    }
    if(sid)fetch(`${A}/api/chat/${sid}`,{method:'DELETE'}).catch(()=>{});
    activeConvo=null; sid=null;
    document.getElementById('chat-msgs').innerHTML='<div class="msg assistant"><div class="tag system">いらっしゃいませ</div><div class="msg-body">New conversation. What do you need?</div></div>';
    renderConvoList();
}
// Keep old newChat for the + New button in chat header
function newChat(){newConvo()}

function deleteConvo(id,e){
    e.stopPropagation();
    convos=convos.filter(x=>x.id!==id);
    localStorage.removeItem('sw-convo-'+id);
    localStorage.setItem('sw-convos',JSON.stringify(convos));
    if(activeConvo===id){activeConvo=null;newConvo()}
    renderConvoList();
}

function renderConvoList(){
    const list=document.getElementById('convo-list');
    if(!list)return;
    list.innerHTML=convos.slice(0,20).map(c=>{
        const active=c.id===activeConvo?'active':'';
        const ago=timeAgo(c.time);
        return `<div class="conv-item ${active}" onclick="switchConvo('${c.id}')" title="${c.title}">
            ${c.title}<span class="ci-time">${ago}</span>
        </div>`;
    }).join('')||'<div style="font-size:0.55rem;color:var(--dim2);padding:0.5rem">No conversations yet</div>';
}

function timeAgo(ts){
    const d=Date.now()-ts;
    if(d<60000)return 'now';
    if(d<3600000)return Math.floor(d/60000)+'m';
    if(d<86400000)return Math.floor(d/3600000)+'h';
    return Math.floor(d/86400000)+'d';
}
document.getElementById('chat-in').addEventListener('keydown',e=>{if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();send()}});

// Sound effects disabled — user preference
function sfxXP(){}
