[Unit]
Description=Hermes Agent (Webhook Gateway)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=%h/hermesagent-taskspine
Environment=HERMES_ENABLE_PROJECT_PLUGINS=1
ExecStart=%h/hermesagent-taskspine/hermes gateway run --replace
Restart=on-failure
RestartSec=2

[Install]
WantedBy=default.target
